import edu.princeton.cs.algs4.StopwatchCPU;
import edu.princeton.cs.algs4.Out;
import edu.princeton.cs.algs4.StdRandom;
import java.util.ArrayList;

public class Experiment {

    private static final String CSV_HEADER = 
        "instancia,estructura,m,purchase_total,query_total,lend_total,receive_total," +
        "dispose_total,query_successful,query_failed,lend_successful,lend_failed," +
        "receive_successful,receive_failed,final_size,final_height,elapsed_seconds";

    static class Stats {
        int compras = 0, consultas = 0, prestamos = 0, recepciones = 0, descartes = 0;
        int consultasOk = 0, consultasFail = 0;
        int prestamosOk = 0, prestamosFail = 0;
        int recepcionesOk = 0, recepcionesFail = 0;
        
        int sizeFinal = 0;
        int alturaFinal = 0;
        double tiempoSegundos = 0.0;
    }

    static void procesarCompra(InventoryIndex index, InventoryOperation op, Stats s) {
        s.compras++;
        if (op.getItem() != null) {
            index.put(op.getKey(), op.getItem());
        } else {
            InventoryItem item = index.get(op.getKey());
            if (item != null) {
                item.addStock(op.getQuantity());
                index.put(op.getKey(), item); 
            }
        }
    }

    static void procesarConsulta(InventoryIndex index, InventoryOperation op, Stats s) {
        s.consultas++;
        InventoryItem item = index.get(op.getKey());
        
        if (item != null) s.consultasOk++;
        else s.consultasFail++;
    }

    static void procesarPrestamo(InventoryIndex index, InventoryOperation op, Stats s) {
        s.prestamos++;
        InventoryItem item = index.get(op.getKey());
        
        if (item != null && item.lend(op.getQuantity())) {
            index.put(op.getKey(), item);
            s.prestamosOk++;
        } else {
            s.prestamosFail++;
        }
    }

    static void procesarRecepcion(InventoryIndex index, InventoryOperation op, Stats s) {
        s.recepciones++;
        InventoryItem item = index.get(op.getKey());
        
        if (item != null && item.receive(op.getQuantity())) {
            index.put(op.getKey(), item);
            s.recepcionesOk++;
        } else {
            s.recepcionesFail++;
        }
    }

    static Stats correrSecuencia(InventoryIndex index, ArrayList<InventoryOperation> operaciones) {
        Stats s = new Stats();
        StopwatchCPU timer = new StopwatchCPU();

        for (InventoryOperation op : operaciones) {
            switch (op.getType()) {
                case PURCHASE:
                    procesarCompra(index, op, s);
                    break;
                case QUERY:
                    procesarConsulta(index, op, s);
                    break;
                case LEND:
                    procesarPrestamo(index, op, s);
                    break;
                case RECEIVE:
                    procesarRecepcion(index, op, s);
                    break;
                case DISPOSE:
                    s.descartes++;
                    index.delete(op.getKey());
                    break;
            }
        }

        s.tiempoSegundos = timer.elapsedTime();
        s.sizeFinal = index.size();
        s.alturaFinal = index.height();

        return s;
    }

    // Valida que las dos implementaciones den el mismo resultado
    static boolean checkValido(InventoryIndex bst, InventoryIndex rb, int m, 
                               Stats sBST, Stats sRB, long seed) {
        boolean todoOk = true;

        if (sBST.sizeFinal != sRB.sizeFinal) {
            System.err.println("-> ERROR: Tamaños no coinciden. Seed: " + seed);
            todoOk = false;
        }

        for (int i = 0; i < 100; i++) {
            int randomKey = StdRandom.uniformInt(1, (m * 4) + 1);
            boolean checkBst = bst.get(randomKey) == null;
            boolean checkRb = rb.get(randomKey) == null;
            
            if (checkBst != checkRb) {
                System.err.println("-> ERROR: Discrepancia en el get para la key " + randomKey + " (seed=" + seed + ")");
                todoOk = false;
            }
        }

        int totalOperacionesBST = sBST.compras + sBST.consultas + sBST.prestamos + sBST.recepciones + sBST.descartes;
        int totalOperacionesRB = sRB.compras + sRB.consultas + sRB.prestamos + sRB.recepciones + sRB.descartes;

        if (totalOperacionesBST != m) {
            System.err.println("-> ERROR: Operaciones BST = " + totalOperacionesBST + ", pero m = " + m);
            todoOk = false;
        }
        if (totalOperacionesRB != m) {
            System.err.println("-> ERROR: Operaciones RB = " + totalOperacionesRB + ", pero m = " + m);
            todoOk = false;
        }

        for (Integer k : bst.keys()) {
            InventoryItem item = bst.get(k);
            if (item == null) continue;
            
            if (item.getStockAvailable() < 0 || item.getStockOnLoan() < 0) {
                System.err.println("-> ERROR FATAL: Stock negativo detectado en key " + k);
                todoOk = false;
            }
            if ((item.getStockAvailable() + item.getStockOnLoan()) != item.getStockTotal()) {
                System.err.println("-> ERROR: Inconsistencia en la suma de stock para key " + k);
                todoOk = false;
            }
        }

        return todoOk;
    }

    static String armarLineaCsv(int instancia, String estructura, int m, Stats s) {
        return String.format("%d,%s,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%s",
            instancia, estructura, m, 
            s.compras, s.consultas, s.prestamos, s.recepciones, s.descartes,
            s.consultasOk, s.consultasFail, s.prestamosOk, s.prestamosFail,
            s.recepcionesOk, s.recepcionesFail, 
            s.sizeFinal, s.alturaFinal, String.valueOf(s.tiempoSegundos)
        );
    }

    public static void runExperiment(int m, int numInstances, String outputDir) {
        int universeSize = 4 * m;
        String filePath = outputDir + "/inventory_experiment_" + m + ".csv";
        
        Out fileOut = new Out(filePath);
        fileOut.println(CSV_HEADER);

        System.out.println("Arrancando simulacion para m = " + m + "...");

        for (int i = 1; i <= numInstances; i++) {
            long currentSeed = (long) m + i;

            ArrayList<InventoryOperation> ops = DataGenerator.generateOperations(m, universeSize, currentSeed);

            BSTInventoryIndex bst = new BSTInventoryIndex();
            Stats bstResults = correrSecuencia(bst, ops);

            RedBlackBSTInventoryIndex rb = new RedBlackBSTInventoryIndex();
            Stats rbResults = correrSecuencia(rb, ops);

            if (!checkValido(bst, rb, m, bstResults, rbResults, currentSeed)) {
                System.err.println("OJO: Instancia " + i + " no paso la validacion (m=" + m + ")");
            }

            // Escribir resultados
            fileOut.println(armarLineaCsv(i, "BST", m, bstResults));
            fileOut.println(armarLineaCsv(i, "RedBlackBST", m, rbResults));
        }

        fileOut.close();
        System.out.println("Archivo guardado con exito: " + filePath);
    }

    public static void main(String[] args) {
        String dir = (args.length > 0) ? args[0] : ".";

        int[] tValues = {12, 13, 14, 15, 16, 17, 18, 19};

        for (int t : tValues) {
            int m = 1 << t; // calculo de potencia de 2 rapido
            runExperiment(m, 30, dir);
        }

        System.out.println("Fin del experimento. Todo listo.");
    }
}